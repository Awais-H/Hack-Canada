{
  "manifest_version": 2,
  "name": "EyeGesturesLite Dwell Capture",
  "version": "0.1.0",
  "description": "Firefox MV2 prototype for EyeGesturesLite-driven gaze dwell screenshots.",
  "applications": {
    "gecko": {
      "id": "eyegestureslite-dwell-capture@example.local",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "downloads",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "shared/browserAdapter.js",
      "shared/messages.js",
      "shared/config.js",
      "shared/storage.js",
      "background/capturePipeline.js",
      "background/background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_title": "EyeGesturesLite Capture",
    "default_popup": "ui/popup.html"
  },
  "web_accessible_resources": [
    "tracking/vendor/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/browserAdapter.js",
        "shared/messages.js",
        "shared/config.js",
        "tracking/vendor/ml.min.js",
        "tracking/vendor/face_mesh.js",
        "tracking/eyeGesturesLiteTracker.js",
        "content/dwellEngine.js",
        "content/overlayManager.js",
        "content/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": "script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self';"
}
